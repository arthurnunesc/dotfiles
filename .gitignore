# Ignore everything by default
*

# Whitelist dotfiles we want to track
!.gitignore
!.ignore
!README.md

# Zsh
!.zshenv
!.config/
!.config/zsh/
!.config/zsh/.zshrc

# Local scripts
!.local/
!.local/bin/
!.local/bin/print-ai-cli-tools

# Starship
!.config/starship/
!.config/starship/starship.toml

# Git
!.config/git/
!.config/git/ignore

# Ghostty
!.config/ghostty/
!.config/ghostty/config.ghostty

# GGA
!.config/gga/
!.config/gga/**

# OpenCode
!.config/opencode/
!.config/opencode/**
.config/opencode/package-lock.json
.config/opencode/context-mode/content/
.config/opencode/context-mode/sessions/

# Pi
!.pi/
!.pi/agent/
!.pi/agent/settings.json
!.pi/agent/mcp.json
!.pi/agent/trust.json
!.pi/agent/extensions/
!.pi/agent/extensions/*.ts
!.pi/agent/extensions/package.json
!.pi/agent/extensions/package-lock.json
!.pi/agent/skills/
!.pi/agent/skills/**

# Codex local files we do want to track
!.codex/
!.codex/skills/
!.codex/skills/**
.codex/skills/_shared
.codex/skills/.system
!.codex/config.toml
!.codex/AGENTS.md
