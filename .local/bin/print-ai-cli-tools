#!/usr/bin/env bash
set -euo pipefail

SCRIPT_FILE="${HOME}/.local/bin/print-ai-cli-tools"

DATA=$(cat <<'EOF'
OpenCode|opencode|https://opencode.ai
Codex CLI|codex|https://github.com/openai/codex
Blackbox CLI|blackbox|https://www.blackbox.ai
EOF
)

if [ "${1:-}" = "edit" ]; then
  if [ -n "${EDITOR:-}" ]; then
    exec "$EDITOR" "$SCRIPT_FILE"
  elif command -v nvim >/dev/null 2>&1; then
    exec nvim "$SCRIPT_FILE"
  elif command -v vim >/dev/null 2>&1; then
    exec vim "$SCRIPT_FILE"
  elif command -v nano >/dev/null 2>&1; then
    exec nano "$SCRIPT_FILE"
  else
    printf "\033[1;31mError:\033[0m No editor found. Set $EDITOR.\n" >&2
    exit 1
  fi
fi

bold=$'\033[1m'
dim=$'\033[2m'
blue=$'\033[34m'
green=$'\033[32m'
reset=$'\033[0m'

printf "${bold}%-20s %-18s %s${reset}\n" "TOOL" "COMMAND" "DOCS"
printf "${dim}%-20s %-18s %s${reset}\n" "--------------------" "------------------" "------------------------------"

while IFS='|' read -r name cmd docs; do
  [ -z "${name:-}" ] && continue
  [[ "$name" =~ ^[[:space:]]*# ]] && continue

  printf "%b%-20s%b %b%-18s%b %b%s%b\n" \
    "$green" "$name" "$reset" \
    "$blue" "$cmd" "$reset" \
    "$dim" "$docs" "$reset"
done <<< "$DATA"
