#!/usr/bin/env bash
set -euo pipefail

FILE="${HOME}/.config/dev-tools/list.txt"

if [ ! -f "$FILE" ]; then
  printf "\033[1;31mError:\033[0m Missing file: %s\n" "$FILE" >&2
  exit 1
fi

if [ "${1:-}" = "edit" ]; then
  if [ -n "${EDITOR:-}" ]; then
    exec "$EDITOR" "$FILE"
  elif command -v nvim >/dev/null 2>&1; then
    exec nvim "$FILE"
  elif command -v vim >/dev/null 2>&1; then
    exec vim "$FILE"
  elif command -v nano >/dev/null 2>&1; then
    exec nano "$FILE"
  else
    printf "\033[1;31mError:\033[0m No editor found. Set $EDITOR.\n" >&2
    exit 1
  fi
fi

bold=$'\033[1m'
dim=$'\033[2m'
blue=$'\033[34m'
green=$'\033[32m'
reset=$'\033[0m'

printf "${bold}%-20s %-18s %s${reset}\n" "TOOL" "COMMAND" "DOCS"
printf "${dim}%-20s %-18s %s${reset}\n" "--------------------" "------------------" "------------------------------"

while IFS='|' read -r name cmd docs; do
  [ -z "${name:-}" ] && continue
  [[ "$name" =~ ^[[:space:]]*# ]] && continue

  printf "%b%-20s%b %b%-18s%b %b%s%b\n" \
    "$green" "$name" "$reset" \
    "$blue" "$cmd" "$reset" \
    "$dim" "$docs" "$reset"
done < "$FILE"
