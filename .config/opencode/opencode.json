{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "explore": {
      "mode": "subagent",
      "model": "commandcode/deepseek/deepseek-v4-flash"
    },
    "general": {
      "mode": "subagent",
      "model": "commandcode/deepseek/deepseek-v4-pro"
    }
  },
  "instructions": [
    "{file:./AGENTS.md}",
    "{file:./AGENTS-personal.md}",
    "{file:./AGENTS-context-mode.md}"
  ],
  "mcp": {
    "chrome-devtools": {
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "type": "local"
    },
    "engram": {
      "command": [
        "/opt/homebrew/opt/engram/bin/engram",
        "mcp",
        "--tools=agent"
      ],
      "type": "local"
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    }
  },
  "provider": {
    "commandcode": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "CommandCode",
      "options": {
        "baseURL": "https://api.commandcode.ai/provider/v1"
      },
      "models": {
        "kimi-k2.6": {
          "name": "Kimi K2.6"
        },
        "kimi-k2.5": {
          "name": "Kimi K2.5"
        },
        "glm-5.1": {
          "name": "GLM-5.1"
        },
        "glm-5": {
          "name": "GLM-5"
        },
        "minimax-m2.7": {
          "name": "MiniMax M2.7"
        },
        "minimax-m2.5": {
          "name": "MiniMax M2.5"
        },
        "deepseek/deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro"
        },
        "deepseek/deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash"
        },
        "qwen3.6-max-preview": {
          "name": "Qwen 3.6 Max Preview"
        },
        "qwen3.6-plus": {
          "name": "Qwen 3.6 Plus"
        },
        "qwen3.7-max": {
          "name": "Qwen 3.7 Max"
        },
        "step-3.5-flash": {
          "name": "Step 3.5 Flash"
        },
        "claude-opus-4-7": {
          "name": "Claude Opus 4.7"
        },
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6"
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6"
        },
        "claude-haiku-4-5": {
          "name": "Claude Haiku 4.5"
        },
        "gpt-5.5": {
          "name": "GPT-5.5"
        },
        "gpt-5.4": {
          "name": "GPT-5.4"
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 Mini"
        },
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex"
        },
        "gemini-3.5-flash": {
          "name": "Gemini 3.5 Flash"
        },
        "gemini-3.1-flash-lite": {
          "name": "Gemini 3.1 Flash Lite"
        },
        "claude-sonnet-4-5": {
          "name": "Claude Sonnet 4.5"
        }
      }
    }
  },
  "plugin": [
    "context-mode",
    "/Users/arthur/.config/opencode/plugins/notify.ts",
    "/Users/arthur/.config/opencode/plugins/rtk.ts",
    "/Users/arthur/.config/opencode/plugins/private-aliases.ts"
  ],
  "permission": {
    "external_directory": {
      "~/Developer/**": "allow",
      "/tmp/**": "allow",
      "/var/folders/cq/*/T/chrome-devtools-mcp-*/**": "allow"
    }
  }
}
