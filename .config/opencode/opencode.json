{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "explore": {
      "mode": "subagent",
      "model": "opencode-go/minimax-m2.7"
    },
    "general": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-pro"
    }
  },
  "instructions": [
    "{file:./AGENTS.md}",
    "{file:./AGENTS-personal.md}"
  ],
  "mcp": {
    "chrome-devtools": {
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "type": "local"
    },
    "engram": {
      "command": [
        "/opt/homebrew/Cellar/engram/1.13.1/bin/engram",
        "mcp",
        "--tools=agent"
      ],
      "type": "local"
    }
  },
  "plugin": [
    "/Users/arthur/.config/opencode/plugins/notify.ts",
    "/Users/arthur/.config/opencode/plugins/rtk.ts",
    "/Users/arthur/.config/opencode/plugins/private-aliases.ts"
  ]
}
