{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "explore": {
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini"
    },
    "general": {
      "mode": "subagent",
      "model": "openai/gpt-5.3-codex"
    }
  },
  "instructions": [
    "{file:./AGENTS.md}",
    "{file:./AGENTS-personal.md}"
  ],
  "mcp": {
    "chrome-devtools": {
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "type": "local"
    },
    "engram": {
      "command": [
        "/opt/homebrew/Cellar/engram/1.13.1/bin/engram",
        "mcp",
        "--tools=agent"
      ],
      "type": "local"
    }
  },
  "plugin": [
    "/Users/arthur/.config/opencode/plugins/notify.ts",
    "opencode-gemini-auth@latest"
  ]
}
