{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "explore": {
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini"
    },
    "general": {
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "variant": "low"
    }
  },
  "instructions": [
    "{file:./AGENTS.md}",
    "{file:./AGENTS-personal.md}"
  ],
  "mcp": {
    "chrome-devtools": {
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "type": "local"
    },
    "engram": {
      "command": [
        "/opt/homebrew/opt/engram/bin/engram",
        "mcp",
        "--tools=agent"
      ],
      "type": "local"
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    }
  },
  "plugin": [
    "/Users/arthur/.config/opencode/plugins/notify.ts",
    "/Users/arthur/.config/opencode/plugins/rtk.ts",
    "/Users/arthur/.config/opencode/plugins/private-aliases.ts"
  ],
  "permission": {
    "external_directory": {
      "~/Developer/**": "allow",
      "/tmp/**": "allow",
      "/var/folders/cq/*/T/chrome-devtools-mcp-*/**": "allow"
    }
  }
}
