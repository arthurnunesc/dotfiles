{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "explore": {
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "variant": "medium"
    },
    "general": {
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "variant": "medium"
    },
    "plan": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    },
    "build": {
      "model": "openai/gpt-5.5",
      "variant": "medium"
    }
  },
  "instructions": [
    "{file:./AGENTS.md}",
    "{file:./AGENTS-personal.md}"
  ],
  "model": "commandcode/deepseek/deepseek-v4-pro",
  "mcp": {
    "chrome-devtools": {
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "type": "local"
    },
    "engram": {
      "command": [
        "/opt/homebrew/opt/engram/bin/engram",
        "mcp",
        "--tools=agent"
      ],
      "type": "local"
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "flyctl": {
      "command": [
        "/opt/homebrew/bin/fly",
        "mcp",
        "server"
      ],
      "type": "local",
      "enabled": true
    }
  },
  "provider": {
    "commandcode": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "CommandCode",
      "options": {
        "baseURL": "https://api.commandcode.ai/provider/v1"
      },
      "models": {
        "moonshotai/Kimi-K2.6": {
          "name": "Kimi K2.6"
        },
        "moonshotai/Kimi-K2.5": {
          "name": "Kimi K2.5"
        },
        "zai-org/GLM-5.1": {
          "name": "GLM-5.1"
        },
        "zai-org/GLM-5": {
          "name": "GLM-5"
        },
        "MiniMaxAI/MiniMax-M3": {
          "name": "MiniMax M3"
        },
        "MiniMaxAI/MiniMax-M2.7": {
          "name": "MiniMax M2.7"
        },
        "MiniMaxAI/MiniMax-M2.5": {
          "name": "MiniMax M2.5"
        },
        "deepseek/deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro"
        },
        "deepseek/deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash"
        },
        "Qwen/Qwen3.6-Max-Preview": {
          "name": "Qwen 3.6 Max Preview"
        },
        "Qwen/Qwen3.6-Plus": {
          "name": "Qwen 3.6 Plus"
        },
        "Qwen/Qwen3.7-Max": {
          "name": "Qwen 3.7 Max"
        },
        "Qwen/Qwen3.7-Plus": {
          "name": "Qwen 3.7 Plus"
        },
        "stepfun/Step-3.7-Flash": {
          "name": "Step 3.7 Flash"
        },
        "stepfun/Step-3.5-Flash": {
          "name": "Step 3.5 Flash"
        },
        "xiaomi/mimo-v2.5-pro": {
          "name": "MiMo V2.5 Pro"
        },
        "xiaomi/mimo-v2.5": {
          "name": "MiMo V2.5"
        },
        "claude-opus-4-8": {
          "name": "Claude Opus 4.8"
        },
        "claude-opus-4-7": {
          "name": "Claude Opus 4.7"
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6"
        },
        "claude-fable-5": {
          "name": "Claude Fable 5"
        },
        "claude-haiku-4-5-20251001": {
